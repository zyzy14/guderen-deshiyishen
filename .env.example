# 古人的深夜食堂 · 大模型接入配置范本
# 用法：把本文件复制为 .env（同目录 /workspace/.env），填入你的密钥，重启预览服务即可。
# server.py 启动时会自动读取 .env（无需改代码、无需改前端）。
#
# 注意：
#   · 二选一即可——要么用「服务商预设」（A），要么用「自定义 OpenAI 兼容端点」（B）。
#   · 没填密钥 = 离线模板模式（本地知识库生成半文白文案，照样能跑）。
#   · 填了密钥并重启 = 大模型润色模式（引子/步骤/题跋由模型重写，更灵动）。

# ─────────────────────────────────────────────
# A. 服务商预设（最简，二选一）
# ─────────────────────────────────────────────
# 通义千问（默认 qwen-plus）
# LLM_PROVIDER=dashscope
# LLM_API_KEY=sk-你的千问key

# DeepSeek（默认 deepseek-chat）
# LLM_PROVIDER=deepseek
# LLM_API_KEY=sk-你的deepseekkey

# OpenAI（默认 gpt-4o-mini）
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-你的openaikey

# 本地 Ollama（key 可空，默认 qwen2.5:latest）
# LLM_PROVIDER=ollama
# LLM_API_KEY=

# ─────────────────────────────────────────────
# B. 自定义 OpenAI 兼容端点（二选一）
#     适用于任意兼容 /v1/chat/completions 的服务
# ─────────────────────────────────────────────
# OPENAI_BASE_URL=https://你的端点/v1
# LLM_API_KEY=你的key
# LLM_MODEL=模型名

# 可选覆盖：默认模型（不写则用服务商默认值）
# LLM_MODEL=qwen-max

# 可选：AI 绘图（前端当前未接入展示，预留）
# IMAGE_GEN_KEY=与 LLM_API_KEY 相同则可不填
# IMAGE_GEN_MODEL=dall-e-3
